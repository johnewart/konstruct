{
  "name": "konstruct-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-http-header-size=32768' concurrently \"node --watch --import tsx src/backend/index.ts\" \"vite\"",
    "dev:no-reload": "NO_HOT_RELOAD=1 concurrently \"node --import tsx src/backend/index.ts\" \"vite\"",
    "server": "node --watch --import tsx src/backend/index.ts",
    "server:no-watch": "node --import tsx src/backend/index.ts",
    "frontend": "vite", 
    "agent": "node --import tsx src/agent/agent-worker.ts",
    "agent:start": "node --import tsx src/agent/agent-worker.ts",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node --import tsx src/backend/index.ts",
    "apply-tree-sitter-patches": "cd node_modules/tree-sitter && patch -p1 < ../../patches/tree-sitter+0.25.0.patch; cd ../tree-sitter-javascript && patch -p1 < ../../patches/tree-sitter-javascript+0.25.0.patch; cd ../tree-sitter-python && patch -p1 < ../../patches/tree-sitter-python+0.25.0.patch; cd ../tree-sitter-typescript && patch -p1 < ../../patches/tree-sitter-typescript+0.23.2.patch",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ci": "vitest --run --coverage",
    "test:unit": "cd src/agent && npm test",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --ext .ts,.tsx",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,html,json}\"",
    "precommit": "lint-staged",
    "prebuild": "npm run lint:fix && npm run format && npm run test:ci"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock": "^3.1000.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1000.0",
    "@aws-sdk/credential-providers": "^3.1000.0",
    "@mantine/core": "^8.3.15",
    "@mantine/form": "^8.3.15",
    "@mantine/hooks": "^8.3.15",
    "@tabler/icons-react": "^3.38.0",
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.11.0",
    "@trpc/react-query": "^11.11.0",
    "@trpc/server": "^11.11.0",
    "@types/readline-sync": "^1.4.8",
    "chalk": "^5.6.2",
    "dockerode": "^4.0.9",
    "dotenv": "^17.3.1",
    "kleur": "^4.1.5",
    "ora": "^9.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "remark-gfm": "^4.0.1",
    "superjson": "^2.2.6",
    "tree-sitter": "^0.25.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "ts-node": "^10.9.2",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dockerode": "^4.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "jest": "^30.2.0",
    "jsdom": "^28.1.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
