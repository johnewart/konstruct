{
  "name": "konstruct-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-http-header-size=32768' concurrently \"bun run server\" \"vite\"",
    "dev:no-reload": "NO_HOT_RELOAD=1 concurrently \"bun run server:no-watch\" \"vite\"",
    "server": "bun --watch src/backend/index.ts",
    "server:no-watch": "bun run src/backend/index.ts",
    "agent": "bun run src/agent/agent-worker.ts",
    "agent:start": "bun run src/agent/agent-worker.ts",
    "build": "vite build",
    "preview": "vite preview",
    "start": "bun run src/backend/index.ts",
    "apply-tree-sitter-patches": "cd node_modules/tree-sitter && patch -p1 < ../../patches/tree-sitter+0.25.0.patch; cd ../tree-sitter-javascript && patch -p1 < ../../patches/tree-sitter-javascript+0.25.0.patch; cd ../tree-sitter-python && patch -p1 < ../../patches/tree-sitter-python+0.25.0.patch; cd ../tree-sitter-typescript && patch -p1 < ../../patches/tree-sitter-typescript+0.23.2.patch",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ci": "vitest --run --coverage",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --ext .ts,.tsx",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,html,json}\"",
    "precommit": "lint-staged",
    "prebuild": "npm run lint:fix && npm run format && npm run test:ci"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.997.0",
    "@aws-sdk/credential-providers": "^3.997.0",
    "@elysiajs/trpc": "^1.1.0",
    "@mantine/core": "^7.0.0",
    "@mantine/form": "^8.3.15",
    "@mantine/hooks": "^7.0.0",
    "@tabler/icons-react": "^3.37.1",
    "@tanstack/react-query": "^5.59.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "@types/readline-sync": "^1.4.8",
    "bun-types": "^1.3.10",
    "chalk": "^5.6.2",
    "dotenv": "^17.3.1",
    "elysia": "^1.2.0",
    "kleur": "^4.1.5",
    "ora": "^9.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.28.0",
    "remark-gfm": "^4.0.0",
    "superjson": "^2.2.1",
    "tree-sitter": "^0.25.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "yaml": "^2.8.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.0.18"
  }
}
